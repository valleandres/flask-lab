# Flask
FLASK_APP=app:create_app
FLASK_DEBUG=1
APP_ENV=development
SECRET_KEY=dev-secret-key-at-least-32-bytes-long
JWT_SECRET_KEY=dev-jwt-secret-key-at-least-32-bytes
SQLALCHEMY_DATABASE_URI=mysql+pymysql://user:password@db:3306/mydatabase
CACHE_TYPE=RedisCache
CACHE_REDIS_URL=redis://redis:6379/0
CACHE_DEFAULT_TIMEOUT=60
CACHE_KEY_PREFIX=flask-lab:
CACHE_REDIS_SOCKET_CONNECT_TIMEOUT=1
CACHE_REDIS_SOCKET_TIMEOUT=1
READINESS_CHECK_CACHE=false

# File storage
STORAGE_BACKEND=local
LOCAL_UPLOAD_FOLDER=uploads

# AWS values are intentionally empty for local development.
AWS_PROFILE=
AWS_REGION=us-east-2
S3_BUCKET_NAME=
S3_UPLOAD_PREFIX=files
S3_PRESIGNED_URL_EXPIRATION=3600
